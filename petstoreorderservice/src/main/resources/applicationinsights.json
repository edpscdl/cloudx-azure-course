{
  "connectionStringConfiguredAtRuntime": true,
  "role": {
    "name": "pet-store-api",
    "instance": "petstoreorderservice"
  },
  "sampling": {
    "percentage": 100
  },
  "jmxMetrics": [
  ],
  "customDimensions": {
  },
